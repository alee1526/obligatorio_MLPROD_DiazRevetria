# Variables de entorno del despliegue.
# docker-compose.prod.yml ya define estos valores por defecto para correr todo
# en una sola instancia, asi que normalmente NO necesitas un .env.
# Este archivo documenta las variables por si queres sobreescribirlas.

# Entorno de la API (informativo).
APP_ENV=prod

# URL con la que la UI (Streamlit) contacta a la API.
# En docker-compose.prod.yml es la red interna de Docker: http://api:8000
# Cambiala solo si corres la UI y la API por separado.
API_URL=http://api:8000
